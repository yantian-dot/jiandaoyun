{
  "name": "jiandaoyun-mcp-plugin",
  "version": "0.5.6",
  "description": "OpenClaw-oriented Jiandaoyun MCP plugin with northwest-company tools, schema cache, and install helpers.",
  "type": "module",
  "bin": {
    "jiandaoyun-mcp": "./dist/index.js",
    "jiandaoyun-openclaw": "./dist/openclaw-cli.js"
  },
  "files": [
    "dist",
    ".codex-plugin",
    ".mcp.json",
    ".env.example",
    "README.md",
    "OPENCLAW_INSTALL.md",
    "references",
    "examples",
    "openclaw",
    "docs/openclaw-weact-adaptation.md",
    "scripts"
  ],
  "scripts": {
    "build": "npm run syntax:check",
    "typecheck": "npm run syntax:check",
    "test": "node scripts/smoke-test.mjs",
    "syntax:check": "for f in dist/*.js scripts/*.mjs; do node --check \"$f\"; done",
    "validate:openclaw": "node scripts/validate-openclaw-tools.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
