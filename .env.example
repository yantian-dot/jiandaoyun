JIANDAOYUN_API_KEY=replace_with_your_api_key
JIANDAOYUN_BASE_URL=https://nocode.pipechina.com.cn
JIANDAOYUN_TIMEOUT_MS=30000
JIANDAOYUN_USER_MAP_FILE=$HOME/.openclaw-main/jiandaoyun-user-map.json
JIANDAOYUN_REQUIRED_FIELDS_FILE=$HOME/.openclaw-main/jiandaoyun-required-fields.json
# caller: backward-compatible; locked: require SenderId/open_id mapping and reject fallback creators.
JIANDAOYUN_CREATOR_POLICY=locked
# When locked-mode open_id is not directly mapped, try WeACT identity lookup.
JIANDAOYUN_WEACT_IDENTITY_LOOKUP=auto
JIANDAOYUN_WEACT_CLI_BIN=weact-cli
JIANDAOYUN_WEACT_CLI_AUTH=bot
JIANDAOYUN_WEACT_IDENTITY_TIMEOUT_MS=5000
# Comma-separated WeACT identity fields that may be used as keys in JIANDAOYUN_USER_MAP_FILE.
JIANDAOYUN_WEACT_IDENTITY_MAP_FIELDS=open_id,user_id,union_id,employee_no,employee_number,job_number,work_id,employee_id,email,enterprise_email
# Optional: directly use a trusted WeACT identity field as Jiandaoyun data_creator.
# Only enable this if that field is guaranteed to equal a unique Jiandaoyun username.
# JIANDAOYUN_WEACT_CREATOR_FIELD=name
# Optional single-user fallback. Prefer locked SenderId/open_id mapping when multiple users will use the assistant.
# JIANDAOYUN_DEFAULT_DATA_CREATOR=replace_with_jiandaoyun_username
